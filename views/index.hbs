<div class="page">
    <div class="dashboard">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">📁</div>
                <div class="stat-value">{{stats.totalProjects}}</div>
                <div class="stat-label">项目</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📋</div>
                <div class="stat-value">{{stats.totalTests}}</div>
                <div class="stat-label">测试用例</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">▶️</div>
                <div class="stat-value">{{stats.totalExecutions}}</div>
                <div class="stat-label">执行次数</div>
            </div>
            <div class="stat-card success">
                <div class="stat-icon">✓</div>
                <div class="stat-value">{{stats.passedExecutions}}</div>
                <div class="stat-label">通过</div>
            </div>
            <div class="stat-card danger">
                <div class="stat-icon">✗</div>
                <div class="stat-value">{{stats.failedExecutions}}</div>
                <div class="stat-label">失败</div>
            </div>
        </div>

        <div class="main-content">
        <div class="left-panel">
            <div class="section">
                <h2>项目列表</h2>
                {{#if projects.length}}
                <div class="projects-card-grid">
                    {{#each projects}}
                        <div class="project-card-item" onclick="window.location.href='/projects/{{this.id}}'">
                            <div class="project-card-header">
                                <h3>{{this.name}}</h3>
                                <span class="project-card-badge">{{#if this.baseUrl}}已配置{{else}}未配置{{/if}}</span>
                            </div>
                            <p class="project-card-desc">{{this.description}}</p>
                            <div class="project-card-url">
                                <span class="url-label">Base URL:</span>
                                <code>{{this.baseUrl}}</code>
                            </div>
                            <div class="project-card-footer">
                                <span class="project-card-meta">创建于 {{formatDate this.createdAt}}</span>
                            </div>
                        </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="empty-state">
                    <p>暂无项目，<a href="/projects">立即创建</a></p>
                </div>
                {{/if}}
            </div>

            <div class="quick-actions" style="margin-top: 30px;">
                <h2>快速操作</h2>
                <div class="action-buttons">
                    <a href="/projects" class="btn btn-primary">+ 创建项目</a>
                    <a href="/test-cases" class="btn btn-secondary">管理测试用例</a>
                    <a href="/settings" class="btn btn-secondary">⚙️ 系统设置</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.projects-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.project-card-item {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    position: relative;
    overflow: hidden;
}

.project-card-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.project-card-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.2);
    background: rgba(255, 255, 255, 0.9);
}

.project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
}

.project-card-header h3 {
    font-size: 18px;
    color: #1f2937;
    font-weight: 600;
    margin: 0;
}

.project-card-badge {
    background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
    color: white;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
}

.project-card-badge:empty {
    background: linear-gradient(135deg, #9ca3af 0%, #d1d5db 100%);
}

.project-card-desc {
    color: #6b7280;
    font-size: 14px;
    margin-bottom: 16px;
    line-height: 1.5;
    min-height: 42px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

.project-card-url {
    background: rgba(249, 250, 251, 0.6);
    backdrop-filter: blur(4px);
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 16px;
    border: 1px solid rgba(229, 231, 235, 0.4);
}

.project-card-url .url-label {
    font-size: 12px;
    color: #9ca3af;
    display: block;
    margin-bottom: 4px;
}

.project-card-url code {
    color: #dc2626;
    font-size: 12px;
    word-break: break-all;
}

.project-card-footer {
    padding-top: 12px;
    border-top: 1px solid rgba(229, 231, 235, 0.4);
}

.project-card-meta {
    font-size: 12px;
    color: #9ca3af;
}
</style>

<script>
function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('zh-CN', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
    });
}
</script>
