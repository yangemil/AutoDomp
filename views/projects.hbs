<div class="page">
    <div class="page-header">
        <h1>项目管理</h1>
        <button class="btn btn-primary" onclick="showCreateProjectModal()">+ 创建项目</button>
    </div>

    <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
        <label class="checkbox" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
            <input type="checkbox" id="showDeleted" onchange="loadProjects()">
            显示已删除的项目
        </label>
    </div>

    <div class="projects-grid" id="projectsContainer">
        <div class="empty-state"><p>加载中...</p></div>
    </div>
</div>

<!-- 项目表单模态框 -->
<div id="projectModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">创建项目</h2>
            <button class="modal-close" onclick="closeProjectModal()">&times;</button>
        </div>
        <form id="projectForm">
            <div class="form-group">
                <label>项目名称 *</label>
                <input type="text" id="projectName" required>
            </div>
            <div class="form-group">
                <label>项目描述</label>
                <textarea id="projectDescription" rows="2"></textarea>
            </div>
            <div class="form-group">
                <label>Base URL</label>
                <input type="url" id="projectBaseUrl" placeholder="https://example.com">
            </div>
            <div class="form-group">
                <label>飞书 Webhook URL</label>
                <input type="url" id="projectFeishuWebhook" placeholder="https://open.feishu.cn/open-apis/bot/v2/hook/xxx">
                <small style="color: #666;">用于定时任务执行完成后发送通知</small>
            </div>
            <div class="form-row" style="gap: 10px; flex-wrap: wrap;">
                <div class="form-group" style="min-width: 120px; display: flex; align-items: center; flex: 1;">
                    <label style="display: flex; align-items: center; margin: 0; white-space: nowrap;">
                        <input type="checkbox" id="projectHeadless" style="margin-right: 5px;">
                        无界面模式
                    </label>
                </div>
                <div class="form-group" style="min-width: 100px; flex: 1;">
                    <label style="font-size: 12px;">慢速模式 (ms)</label>
                    <input type="number" id="projectSlowMo" value="200" min="0" style="padding: 6px 8px;">
                </div>
                <div class="form-group" style="min-width: 100px; flex: 1;">
                    <label style="font-size: 12px;">超时时间 (ms)</label>
                    <input type="number" id="projectTimeout" value="30000" style="padding: 6px 8px;">
                </div>
                <div class="form-group" style="min-width: 100px; flex: 1;">
                    <label style="font-size: 12px;">步骤间隔 (ms)</label>
                    <input type="number" id="projectWaitAfter" value="0" style="padding: 6px 8px;">
                </div>
            </div>
            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="closeProjectModal()">取消</button>
                <button type="submit" class="btn btn-primary">保存</button>
            </div>
        </form>
    </div>
</div>

<script>
let editingProjectId = null;

async function loadProjects() {
    const showDeleted = document.getElementById('showDeleted').checked;
    const url = showDeleted ? '/api/projects?includeDeleted=true' : '/api/projects';
    
    try {
        const response = await fetch(url);
        const projects = await response.json();
        renderProjects(projects, showDeleted);
    } catch (error) {
        console.error('加载项目失败:', error);
    }
}

function renderProjects(projects, showDeleted) {
    const container = document.querySelector('.projects-grid');
    
    if (projects.length === 0) {
        container.innerHTML = '<div class="empty-state"><p>暂无项目</p></div>';
        return;
    }
    
    let html = '';
    projects.forEach(project => {
        const isDeleted = project.deleted;
        const badge = isDeleted 
            ? '<span class="project-badge" style="background: #ef4444;">已删除</span>'
            : (project.baseUrl 
                ? '<span class="project-badge">已配置</span>' 
                : '<span class="project-badge" style="background: #f59e0b;">未配置</span>');
        
        html += `
        <div class="project-card" style="${isDeleted ? 'opacity: 0.7;' : ''}">
            <div class="project-header">
                <h2>${project.name}</h2>
                ${badge}
            </div>
            <p class="project-description">${project.description || ''}</p>
            <div class="project-meta">
                <span>Base URL: ${project.baseUrl || '-'}</span>
            </div>
            <div class="project-actions">
                <a href="/projects/${project.id}" class="btn btn-sm">查看详情</a>
                ${!isDeleted && project.id !== 'default-project' ? `
                <button class="btn btn-sm btn-secondary" onclick="editProject('${project.id}')">编辑</button>
                <button class="btn btn-sm btn-danger" onclick="deleteProject('${project.id}')">删除</button>
                ` : ''}
                ${isDeleted && project.id !== 'default-project' ? `
                <button class="btn btn-sm btn-primary" onclick="restoreProject('${project.id}')">恢复</button>
                ` : ''}
            </div>
        </div>`;
    });
    
    container.innerHTML = html;
}

async function restoreProject(projectId) {
    if (!confirm('确定要恢复这个项目吗？')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/projects/${projectId}/restore`, {
            method: 'POST'
        });
        const result = await response.json();
        
        if (result.success) {
            alert('恢复成功！');
            loadProjects();
        } else {
            alert('恢复失败: ' + result.error);
        }
    } catch (error) {
        alert('请求失败: ' + error.message);
    }
}

function showCreateProjectModal() {
    editingProjectId = null;
    document.getElementById('modalTitle').textContent = '创建项目';
    document.getElementById('projectForm').reset();
    document.getElementById('projectModal').style.display = 'flex';
}

function closeProjectModal() {
    document.getElementById('projectModal').style.display = 'none';
    editingProjectId = null;
}

async function editProject(projectId) {
    editingProjectId = projectId;
    document.getElementById('modalTitle').textContent = '编辑项目';
    
    try {
        const response = await fetch(`/api/projects/${projectId}`);
        const project = await response.json();
        
        document.getElementById('projectName').value = project.name;
        document.getElementById('projectDescription').value = project.description || '';
        document.getElementById('projectBaseUrl').value = project.baseUrl || '';
        document.getElementById('projectFeishuWebhook').value = project.feishuWebhook || '';
        document.getElementById('projectHeadless').checked = project.settings?.headless || false;
        document.getElementById('projectSlowMo').value = project.settings?.slowMo || 200;
        document.getElementById('projectTimeout').value = project.settings?.timeout || 30000;
        document.getElementById('projectWaitAfter').value = project.settings?.waitAfter || 0;
        
        document.getElementById('projectModal').style.display = 'flex';
    } catch (error) {
        alert('加载项目失败: ' + error.message);
    }
}

async function deleteProject(projectId) {
    if (!confirm('确定要删除这个项目吗？项目下的所有测试用例和执行记录都会被删除！')) {
        return;
    }

    try {
        const response = await fetch(`/api/projects/${projectId}`, {
            method: 'DELETE'
        });
        const result = await response.json();

        if (result.success) {
            alert('删除成功！');
            window.location.reload();
        } else {
            alert('删除失败: ' + result.error);
        }
    } catch (error) {
        alert('请求失败: ' + error.message);
    }
}

document.getElementById('projectForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const projectData = {
        name: document.getElementById('projectName').value,
        description: document.getElementById('projectDescription').value,
        baseUrl: document.getElementById('projectBaseUrl').value,
        feishuWebhook: document.getElementById('projectFeishuWebhook').value || undefined,
        settings: {
            headless: document.getElementById('projectHeadless').checked,
            slowMo: parseInt(document.getElementById('projectSlowMo').value),
            screenshot: {
                enabled: true,
                onStep: false,
                onFailure: true
            },
            timeout: parseInt(document.getElementById('projectTimeout').value),
            waitAfter: parseInt(document.getElementById('projectWaitAfter').value) || 0
        }
    };

    try {
        const url = editingProjectId ? `/api/projects/${editingProjectId}` : '/api/projects';
        const method = editingProjectId ? 'PUT' : 'POST';

        const response = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(projectData)
        });
        const result = await response.json();

        if (!result.error) {
            alert('保存成功！');
            closeProjectModal();
            window.location.reload();
        } else {
            alert('保存失败: ' + result.error);
        }
    } catch (error) {
        alert('请求失败: ' + error.message);
    }
});

window.onload = function() {
    loadProjects();
};
</script>

