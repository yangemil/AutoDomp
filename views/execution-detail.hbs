<div class="page">
    <div class="page-header">
        <h1>执行详情</h1>
        <a href="/executions" class="back-link">← 返回执行记录</a>
    </div>

    <div class="execution-detail">
        <div class="detail-card">
            <div class="detail-item">
                <label>{{#if execution.scenarioName}}场景名称{{else}}测试用例{{/if}}</label>
                <div>{{execution.scenarioName}}{{execution.testCaseName}}</div>
            </div>
            <div class="detail-item">
                <label>状态</label>
                <div><span class="status-badge status-{{execution.status}}">{{execution.status}}</span></div>
            </div>
            <div class="detail-item">
                <label>开始时间</label>
                <div>{{formatDate execution.startTime}}</div>
            </div>
            <div class="detail-item">
                <label>耗时</label>
                <div>{{formatDuration execution.duration}}</div>
            </div>
            <div class="detail-item">
                <label>{{#if execution.scenarioName}}测试用例数{{else}}步骤数{{/if}}</label>
                <div>{{#if execution.scenarioName}}{{execution.totalTests}}{{else}}{{execution.steps.length}}{{/if}}</div>
            </div>
            {{#if execution.passedTests}}
            <div class="detail-item">
                <label>通过/失败</label>
                <div>
                    <span class="result-passed">{{execution.passedTests}} 通过</span> / 
                    <span class="result-failed">{{execution.failedTests}} 失败</span>
                </div>
            </div>
            {{/if}}
        </div>

        {{#if execution.error}}
        <div class="error-section">
            <h2>错误信息</h2>
            <div class="error-message">{{execution.error}}</div>
        </div>
        {{/if}}

        {{#if execution.steps}}
        <div class="steps-section">
            <h2>执行步骤</h2>
            <table class="table">
                <thead>
                    <tr>
                        <th>序号</th>
                        <th>动作</th>
                        <th>描述</th>
                        <th>状态</th>
                        <th>耗时</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each execution.steps}}
                    <tr class="step-{{this.status}}">
                        <td>{{this.order}}</td>
                        <td>{{this.action}}</td>
                        <td>{{this.description}}</td>
                        <td><span class="status-badge status-{{this.status}}">{{this.status}}</span></td>
                        <td>{{formatDuration this.duration}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}

        {{#if execution.screenshots}}
        <div class="screenshots-section">
            <h2>执行截图</h2>
            <div class="screenshots-grid">
                {{#each execution.screenshots}}
                <div class="screenshot-item">
                    <img src="/data/screenshots/{{this}}" alt="执行截图">
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}

        {{#if execution.logs}}
        <div class="logs-section">
            <h2>执行日志</h2>
            <div class="logs-list">
                {{#each execution.logs}}
                    <div class="log-item">{{this}}</div>
                {{/each}}
            </div>
        </div>
        {{/if}}
    </div>
</div>

<script>
function formatDuration(duration) {
    if (!duration) return '-';
    const seconds = duration / 1000;
    if (seconds < 60) {
        return Math.round(seconds) + ' 秒';
    } else {
        const minutes = Math.floor(seconds / 60);
        const remainingSeconds = Math.round(seconds % 60);
        return minutes + ' 分 ' + remainingSeconds + ' 秒';
    }
}

function formatDate(dateStr) {
    const date = new Date(dateStr);
    return date.toLocaleString('zh-CN');
}
</script>

