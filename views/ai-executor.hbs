<div class="page">
    <div class="page-header">
        <h1>🤖 AI 测试执行器</h1>
        <p>通过自然语言描述测试过程，AI自动控制浏览器执行</p>
    </div>

    <div class="ai-executor-container">
        <div class="ai-chat-section">
            <div class="chat-header">
                <h2>测试指令输入</h2>
            </div>
            <div class="chat-input-area">
                <textarea 
                    id="aiInstruction" 
                    rows="8" 
                    placeholder="请输入测试指令，每行一个操作，例如：
1、访问 https://litemall.hogwarts.ceshiren.com/#/login
2、点击登录按钮
3、展开一级菜单 商场管理
4、点击添加按钮
5、在问题输入框输入问题001"
                ></textarea>
                <div class="chat-actions">
                    <button class="btn btn-primary" onclick="executeAI()">🚀 执行测试</button>
                    <button class="btn btn-secondary" onclick="stopExecution()">⏹ 停止</button>
                    <button class="btn btn-secondary" onclick="clearChat()">🗑 清空</button>
                </div>
            </div>
        </div>

        <div class="ai-result-section">
            <div class="result-header">
                <h2>执行结果</h2>
                <span id="executionStatus" class="status-badge"></span>
            </div>
            <div id="executionResults" class="execution-results">
                <p style="color: #999; text-align: center; padding: 40px;">
                    执行结果将显示在这里...
                </p>
            </div>
        </div>
    </div>

    <div class="execution-steps-section">
        <h2>执行步骤详情</h2>
        <div id="stepsList" class="steps-list">
            <p style="color: #999; text-align: center; padding: 20px;">
                暂无执行步骤
            </p>
        </div>
    </div>
</div>

<style>
.ai-executor-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.ai-chat-section, .ai-result-section {
    background: white;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.chat-header, .result-header {
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chat-header h2, .result-header h2 {
    margin: 0;
    font-size: 18px;
    color: #333;
}

.chat-input-area textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    font-family: inherit;
    resize: vertical;
    box-sizing: border-box;
}

.chat-input-area textarea:focus {
    outline: none;
    border-color: #409eff;
}

.chat-actions {
    margin-top: 15px;
    display: flex;
    gap: 10px;
}

.execution-results {
    max-height: 400px;
    overflow-y: auto;
    background: #f9f9f9;
    border-radius: 6px;
    padding: 15px;
    min-height: 200px;
}

.status-badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
}

.status-badge.pending {
    background: #e6a23c;
    color: white;
}

.status-badge.running {
    background: #409eff;
    color: white;
}

.status-badge.completed {
    background: #67c23a;
    color: white;
}

.status-badge.failed {
    background: #f56c6c;
    color: white;
}

.execution-steps-section {
    background: white;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.execution-steps-section h2 {
    margin: 0 0 15px 0;
    font-size: 18px;
    color: #333;
}

.steps-list {
    max-height: 500px;
    overflow-y: auto;
}

.step-item {
    display: flex;
    align-items: flex-start;
    padding: 12px;
    margin-bottom: 10px;
    background: #f9f9f9;
    border-radius: 6px;
    border-left: 4px solid #ddd;
}

.step-item.pending {
    border-left-color: #e6a23c;
}

.step-item.running {
    border-left-color: #409eff;
}

.step-item.completed {
    border-left-color: #67c23a;
}

.step-item.failed {
    border-left-color: #f56c6c;
}

.step-number {
    min-width: 30px;
    height: 30px;
    background: #ddd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    margin-right: 12px;
}

.step-item.completed .step-number {
    background: #67c23a;
    color: white;
}

.step-item.failed .step-number {
    background: #f56c6c;
    color: white;
}

.step-content {
    flex: 1;
}

.step-action {
    font-weight: 600;
    color: #333;
    margin-bottom: 4px;
}

.step-description {
    color: #666;
    font-size: 13px;
}

.step-selector {
    font-family: monospace;
    font-size: 12px;
    color: #409eff;
    background: #ecf5ff;
    padding: 2px 6px;
    border-radius: 3px;
    margin-top: 4px;
}

.step-value {
    font-family: monospace;
    font-size: 12px;
    color: #67c23a;
    background: #f0f9eb;
    padding: 2px 6px;
    border-radius: 3px;
    margin-top: 4px;
}

.step-result {
    margin-top: 8px;
    font-size: 12px;
    color: #666;
}

.step-error {
    margin-top: 8px;
    font-size: 12px;
    color: #f56c6c;
    background: #fef0f0;
    padding: 4px 8px;
    border-radius: 3px;
}

.step-screenshot {
    margin-top: 8px;
}

.step-screenshot img {
    max-width: 200px;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid #ddd;
}

.step-screenshot img:hover {
    border-color: #409eff;
}

.loading-spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 3px solid #f3f3f3;
    border-top: 3px solid #409eff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-right: 8px;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
</style>

<script>
let isExecuting = false;

async function executeAI() {
    const instruction = document.getElementById('aiInstruction').value.trim();
    
    if (!instruction) {
        alert('请输入测试指令');
        return;
    }

    if (isExecuting) {
        alert('正在执行中，请稍候...');
        return;
    }

    isExecuting = true;
    
    const resultsDiv = document.getElementById('executionResults');
    const stepsDiv = document.getElementById('stepsList');
    const statusBadge = document.getElementById('executionStatus');
    
    resultsDiv.innerHTML = '<div style="text-align: center; padding: 40px;"><span class="loading-spinner"></span><br>正在解析指令并执行...</div>';
    statusBadge.className = 'status-badge running';
    statusBadge.textContent = '执行中';

    try {
        const response = await fetch('/api/ai/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ instruction })
        });
        
        const result = await response.json();
        
        if (result.success) {
            statusBadge.className = 'status-badge completed';
            statusBadge.textContent = '执行完成';
            resultsDiv.innerHTML = `<div style="padding: 10px; background: #d4edda; border-radius: 4px; color: #155724;">✅ ${result.summary}</div>`;
            
            renderSteps(result.steps);
        } else {
            statusBadge.className = 'status-badge failed';
            statusBadge.textContent = '执行失败';
            resultsDiv.innerHTML = `<div style="padding: 10px; background: #f8d7da; border-radius: 4px; color: #721c24;">❌ ${result.error || result.summary}</div>`;
        }
    } catch (error) {
        statusBadge.className = 'status-badge failed';
        statusBadge.textContent = '执行失败';
        resultsDiv.innerHTML = `<div style="padding: 10px; background: #f8d7da; border-radius: 4px; color: #721c24;">❌ 执行失败: ${error.message}</div>`;
    } finally {
        isExecuting = false;
    }
}

function renderSteps(steps) {
    const stepsDiv = document.getElementById('stepsList');
    
    if (!steps || steps.length === 0) {
        stepsDiv.innerHTML = '<p style="color: #999; text-align: center; padding: 20px;">暂无执行步骤</p>';
        return;
    }
    
    stepsDiv.innerHTML = steps.map((step, index) => `
        <div class="step-item ${step.status}">
            <div class="step-number">${index + 1}</div>
            <div class="step-content">
                <div class="step-action">${getActionText(step.action)}</div>
                <div class="step-description">${step.description || '-'}</div>
                ${step.selector ? `<div class="step-selector">选择器: ${step.selector}</div>` : ''}
                ${step.value ? `<div class="step-value">值: ${step.value}</div>` : ''}
                ${step.result ? `<div class="step-result">${step.result}</div>` : ''}
                ${step.error ? `<div class="step-error">❌ ${step.error}</div>` : ''}
                ${step.screenshot ? `<div class="step-screenshot"><img src="/data/ai-screenshots/${step.screenshot}" onclick="window.open(this.src)" title="点击查看大图"></div>` : ''}
            </div>
        </div>
    `).join('');
}

function getActionText(action) {
    const actionMap = {
        'navigate': '🌐 导航',
        'click': '👆 点击',
        'fill': '⌨️ 填写',
        'select': '📋 选择',
        'wait': '⏳ 等待',
        'hover': '👆 悬停'
    };
    return actionMap[action] || action;
}

async function stopExecution() {
    try {
        await fetch('/api/ai/execute/close', { method: 'POST' });
        isExecuting = false;
        alert('已停止执行');
    } catch (error) {
        console.error('停止失败:', error);
    }
}

function clearChat() {
    document.getElementById('aiInstruction').value = '';
    document.getElementById('executionResults').innerHTML = '<p style="color: #999; text-align: center; padding: 40px;">执行结果将显示在这里...</p>';
    document.getElementById('stepsList').innerHTML = '<p style="color: #999; text-align: center; padding: 20px;">暂无执行步骤</p>';
    document.getElementById('executionStatus').className = 'status-badge';
    document.getElementById('executionStatus').textContent = '';
}
</script>
