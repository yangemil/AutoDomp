<div class="page">
    <div class="page-header">
        <h1>执行详情</h1>
        <a href="/executions" class="back-link">← 返回执行记录</a>
    </div>

    <div class="detail-card">
        <div class="detail-item">
            <label>{{#if execution.scenarioName}}场景名称{{else}}测试用例{{/if}}</label>
            <div>{{execution.scenarioName}}{{execution.testCaseName}}</div>
        </div>
        <div class="detail-item">
            <label>状态</label>
            <div><span class="status-badge status-{{execution.status}}">{{execution.status}}</span></div>
        </div>
        <div class="detail-item">
            <label>开始时间</label>
            <div>{{formatDate execution.startTime}}</div>
        </div>
        <div class="detail-item">
            <label>耗时</label>
            <div>{{formatDuration execution.duration}}</div>
        </div>
        <div class="detail-item">
            <label>{{#if execution.scenarioName}}测试用例数{{else}}步骤数{{/if}}</label>
            <div>{{#if execution.scenarioName}}{{execution.totalTests}}{{else}}{{execution.steps.length}}{{/if}}</div>
        </div>
        {{#if execution.passedTests}}
        <div class="detail-item">
            <label>通过/失败</label>
            <div>
                <span class="result-passed">{{execution.passedTests}} 通过</span> / 
                <span class="result-failed">{{execution.failedTests}} 失败</span>
            </div>
        </div>
        {{/if}}
    </div>

    <!-- 性能指标面板 -->
    {{#if execution.performanceMetrics}}
    <div class="section-card">
        <div class="section-header">
            <h2>📊 性能指标</h2>
        </div>
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-value">{{formatDuration execution.performanceMetrics.totalDuration}}</div>
                <div class="metric-label">总耗时</div>
            </div>
            <div class="metric-card">
                <div class="metric-value">{{formatDuration execution.performanceMetrics.averageStepDuration}}</div>
                <div class="metric-label">平均步骤耗时</div>
            </div>
            <div class="metric-card highlight">
                <div class="metric-value">
                    <span>步骤 {{execution.performanceMetrics.slowestStep.order}}</span>
                    <small>{{execution.performanceMetrics.slowestStep.action}}</small>
                </div>
                <div class="metric-label">最慢步骤</div>
                <div class="metric-duration">{{formatDuration execution.performanceMetrics.slowestStep.duration}}</div>
            </div>
            <div class="metric-card">
                <div class="metric-value">{{execution.performanceMetrics.elementInteractions}}</div>
                <div class="metric-label">元素交互次数</div>
            </div>
        </div>
        
        {{#if execution.performanceMetrics.pageLoadTimes}}
        <div class="page-load-times">
            <h4>页面加载时间</h4>
            <div class="timeline-bar">
                {{#each execution.performanceMetrics.pageLoadTimes as time}}
                <div class="timeline-segment" style="width: {{calcPercent time execution.performanceMetrics.totalDuration}}%;">
                    <span class="tooltip">{{formatDuration time}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{/if}}
    </div>
    {{/if}}

    <!-- 环境信息面板 -->
    {{#if execution.environmentInfo}}
    <div class="section-card">
        <div class="section-header">
            <h2>🖥️ 环境信息</h2>
        </div>
        <div class="env-grid">
            <div class="env-item">
                <span class="env-label">操作系统</span>
                <span class="env-value">{{execution.environmentInfo.os}} {{execution.environmentInfo.osVersion}}</span>
            </div>
            <div class="env-item">
                <span class="env-label">Node.js 版本</span>
                <span class="env-value">{{execution.environmentInfo.nodeVersion}}</span>
            </div>
            <div class="env-item">
                <span class="env-label">浏览器</span>
                <span class="env-value">{{execution.environmentInfo.browserVersion}}</span>
            </div>
            <div class="env-item">
                <span class="env-label">分辨率</span>
                <span class="env-value">{{execution.environmentInfo.resolution}}</span>
            </div>
            <div class="env-item">
                <span class="env-label">时区</span>
                <span class="env-value">{{execution.environmentInfo.timezone}}</span>
            </div>
            <div class="env-item">
                <span class="env-label">测试平台</span>
                <span class="env-value">{{execution.environmentInfo.testPlatform}} v{{execution.environmentInfo.testPlatformVersion}}</span>
            </div>
        </div>
    </div>
    {{/if}}

    <!-- 结构化日志面板 -->
    <div class="section-card">
        <div class="section-header">
            <h2>📝 执行日志</h2>
            <div class="log-actions">
                <button class="btn btn-sm" onclick="filterLogs('all')">全部</button>
                <button class="btn btn-sm btn-error" onclick="filterLogs('error')">错误</button>
                <button class="btn btn-sm btn-warn" onclick="filterLogs('warn')">警告</button>
                <button class="btn btn-sm btn-info" onclick="filterLogs('info')">信息</button>
                <button class="btn btn-sm btn-debug" onclick="filterLogs('debug')">调试</button>
                <a href="/api/executions/{{execution.id}}/export-logs/json" class="btn btn-sm btn-secondary" target="_blank">导出 JSON</a>
                <a href="/api/executions/{{execution.id}}/export-logs/csv" class="btn btn-sm btn-secondary" target="_blank">导出 CSV</a>
            </div>
        </div>
        
        {{#if execution.structuredLogs}}
        <div class="log-summary">
            <span class="log-count">共 {{execution.structuredLogs.length}} 条日志</span>
            {{#if logsSummary}}
            <span class="log-levels">
                <span class="level-badge level-debug">{{logsSummary.byLevel.debug}} DEBUG</span>
                <span class="level-badge level-info">{{logsSummary.byLevel.info}} INFO</span>
                <span class="level-badge level-warn">{{logsSummary.byLevel.warn}} WARN</span>
                <span class="level-badge level-error">{{logsSummary.byLevel.error}} ERROR</span>
            </span>
            {{/if}}
        </div>
        
        <div class="structured-logs" id="structuredLogs">
            {{#each execution.structuredLogs}}
            <div class="log-entry log-{{this.level}}" data-level="{{this.level}}">
                <span class="log-time">{{formatTime this.timestamp}}</span>
                <span class="log-level {{this.level}}">[{{uppercase this.level}}]</span>
                <span class="log-message">{{this.message}}</span>
                {{#if this.stepOrder}}
                <span class="log-step">步骤 {{this.stepOrder}}</span>
                {{/if}}
                {{#if this.metadata.duration}}
                <span class="log-duration">{{this.metadata.duration}}ms</span>
                {{/if}}
                {{#if this.metadata.action}}
                <span class="log-action">{{this.metadata.action}}</span>
                {{/if}}
            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="no-logs">
            <p>暂无结构化日志</p>
            <p class="help-text">旧版执行记录不包含结构化日志数据</p>
        </div>
        {{/if}}
    </div>

    {{#if execution.error}}
    <div class="error-section">
        <h2>错误信息</h2>
        <div class="error-message">{{execution.error}}</div>
    </div>
    {{/if}}

    {{#if execution.steps}}
    <div class="steps-section">
        <h2>执行步骤</h2>
        <table class="table">
            <thead>
                <tr>
                    <th>序号</th>
                    <th>动作</th>
                    <th>描述</th>
                    <th>状态</th>
                    <th>耗时</th>
                </tr>
            </thead>
            <tbody>
                {{#each execution.steps}}
                <tr class="step-{{this.status}}">
                    <td>{{this.order}}</td>
                    <td>{{this.action}}</td>
                    <td>{{this.description}}</td>
                    <td><span class="status-badge status-{{this.status}}">{{this.status}}</span></td>
                    <td>{{formatDuration this.duration}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{/if}}

    {{#if execution.screenshots}}
    <div class="screenshots-section">
        <h2>执行截图</h2>
        <div class="screenshots-grid">
            {{#each execution.screenshots}}
            <div class="screenshot-item">
                <img src="/data/screenshots/{{this}}" alt="执行截图">
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}

    {{#if execution.logs}}
    <div class="logs-section">
        <h2>原始日志</h2>
        <div class="logs-list">
            {{#each execution.logs}}
                <div class="log-item">{{this}}</div>
            {{/each}}
        </div>
    </div>
    {{/if}}
</div>

<script>
function formatDuration(duration) {
    if (!duration) return '-';
    const seconds = duration / 1000;
    if (seconds < 60) {
        return Math.round(seconds) + ' 秒';
    } else {
        const minutes = Math.floor(seconds / 60);
        const remainingSeconds = Math.round(seconds % 60);
        return minutes + ' 分 ' + remainingSeconds + ' 秒';
    }
}

function formatDate(dateStr) {
    if (!dateStr) return '-';
    const date = new Date(dateStr);
    return date.toLocaleString('zh-CN');
}

function formatTime(dateStr) {
    if (!dateStr) return '-';
    const date = new Date(dateStr);
    return date.toLocaleTimeString('zh-CN');
}

function uppercase(str) {
    return str ? str.toUpperCase() : '';
}

function filterLogs(level) {
    const logs = document.querySelectorAll('#structuredLogs .log-entry');
    logs.forEach(log => {
        if (level === 'all' || log.dataset.level === level) {
            log.style.display = 'flex';
        } else {
            log.style.display = 'none';
        }
    });
    
    // 更新按钮状态
    document.querySelectorAll('.log-actions .btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');
}
</script>

