.level-info { background: #dbeafe; color: #3b82f6; }
.level-warn { background: #fef3c7; color: #f59e0b; }
.level-error { background: #fee2e2; color: #ef4444; }
.logs-section, .raw-section {
    background: white;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 24px;
