<div class="page">
    <div class="page-header">
        <h1>日志查询</h1>
    </div>

    <div class="query-section">
        <div class="query-form">
            <div class="form-group">
                <label>执行ID</label>
                <input type="text" id="executionId" placeholder="请输入执行记录ID" class="form-control">
            </div>
            <div class="form-group">
                <label>执行记录</label>
                <select id="recentExecutions" class="form-control">
                    <option value="">-- 选择执行记录 --</option>
                </select>
            </div>
            <div class="form-group">
                <button onclick="queryExecution()" class="btn btn-primary">查询</button>
                <button onclick="exportJSON()" class="btn btn-secondary">导出 JSON</button>
                <button onclick="exportCSV()" class="btn btn-secondary">导出 CSV</button>
            </div>
        </div>
    </div>

    <div id="resultSection" style="display: none;">
        <div class="cards-row">
            <div class="info-card">
                <div class="card-header">
                    <span class="card-icon">📊</span>
                    <span>日志统计</span>
                </div>
                <div class="card-body" id="logsSummary">
                    <div class="loading">加载中...</div>
                </div>
            </div>

            <div class="info-card">
                <div class="card-header">
                    <span class="card-icon">⚡</span>
                    <span>性能指标</span>
                </div>
                <div class="card-body" id="performanceMetrics">
                    <div class="loading">加载中...</div>
                </div>
            </div>

            <div class="info-card">
                <div class="card-header">
                    <span class="card-icon">🖥️</span>
                    <span>环境信息</span>
                </div>
                <div class="card-body" id="environmentInfo">
                    <div class="loading">加载中...</div>
                </div>
            </div>
        </div>

        <div class="logs-section">
            <div class="section-header">
                <h2>📝 执行日志</h2>
                <div class="log-filters">
                    <button onclick="filterLogs('all')" class="filter-btn active" data-level="all">全部</button>
                    <button onclick="filterLogs('error')" class="filter-btn btn-error" data-level="error">错误</button>
                    <button onclick="filterLogs('warn')" class="filter-btn btn-warn" data-level="warn">警告</button>
                    <button onclick="filterLogs('info')" class="filter-btn btn-info" data-level="info">信息</button>
                    <button onclick="filterLogs('debug')" class="filter-btn btn-debug" data-level="debug">调试</button>
                </div>
            </div>
            <div class="logs-container" id="structuredLogs">
                <div class="empty-message">请先查询执行记录</div>
            </div>
        </div>

        <div class="raw-section">
            <div class="section-header">
                <h2>📄 原始 JSON 数据</h2>
                <button onclick="toggleRawJSON()" class="btn btn-sm btn-secondary" id="toggleRawBtn">展开</button>
            </div>
            <div class="raw-container" id="rawJSON" style="display: none;">
                <pre id="rawJSONContent"></pre>
            </div>
        </div>
    </div>
</div>

<style>
