<script>
let currentExecutionId = '';
let currentLogs = [];

window.onload = function() {
    // 总是加载执行记录下拉框
    loadRecentExecutions();
    
    // 检查URL参数是否有executionId
    const urlParams = new URLSearchParams(window.location.search);
    const executionId = urlParams.get('executionId');
    
    if (executionId) {
        // 延迟一下确保下拉框已加载
        setTimeout(() => {
            document.getElementById('executionId').value = executionId;
            queryExecution();
        }, 100);
    }
};

async function loadRecentExecutions() {
    try {
        const projectId = localStorage.getItem('globalProjectId');
        if (!projectId) return;
        const response = await fetch(`/api/executions?projectId=${projectId}&pageSize=20`);
        const executions = await response.json();
        const select = document.getElementById('recentExecutions');
        select.innerHTML = '<option value="">-- 选择执行记录 --</option>';
        const execList = Array.isArray(executions) ? executions : (executions.data || []);
        execList.slice(0, 20).forEach(exec => {
            const option = document.createElement('option');
            option.value = exec.id;
            const time = new Date(exec.startTime).toLocaleString('zh-CN');
            const status = exec.status === 'passed' ? '✅' : '❌';
            option.textContent = `${status} ${exec.testCaseName || exec.scenarioName || '未知'} - ${time}`;
            select.appendChild(option);
        });
    } catch (error) {
        console.error('加载执行记录失败:', error);
    }
}

document.getElementById('recentExecutions').addEventListener('change', function() {
    const selectedId = this.value;
    if (selectedId) {
        document.getElementById('executionId').value = selectedId;
        queryExecution();
    }
});

async function queryExecution() {
    const execId = document.getElementById('executionId').value.trim();
    if (!execId) { alert('请输入执行ID'); return; }
    currentExecutionId = execId;
    document.getElementById('resultSection').style.display = 'block';
    await Promise.all([loadLogsSummary(), loadPerformance(), loadEnvironment(), loadStructuredLogs()]);
    loadRawJSON();
}

async function loadLogsSummary() {
    try {
        const response = await fetch(`/api/executions/${currentExecutionId}/logs-summary`);
        const summary = await response.json();
        const container = document.getElementById('logsSummary');
        if (summary.error) { container.innerHTML = '<div class="empty-message">暂无日志统计</div>'; return; }
        container.innerHTML = `
            <div class="stat-row"><span class="stat-label">总日志数</span><span class="stat-value">${summary.total}</span></div>
            <div class="stat-row"><span class="stat-label">DEBUG</span><span class="level-badge level-debug">${summary.byLevel.debug}</span></div>
            <div class="stat-row"><span class="stat-label">INFO</span><span class="level-badge level-info">${summary.byLevel.info}</span></div>
            <div class="stat-row"><span class="stat-label">WARN</span><span class="level-badge level-warn">${summary.byLevel.warn}</span></div>
            <div class="stat-row"><span class="stat-label">ERROR</span><span class="level-badge level-error">${summary.byLevel.error}</span></div>
            <div class="stat-row"><span class="stat-label">CRITICAL</span><span class="level-badge level-error">${summary.byLevel.critical}</span></div>
        `;
    } catch (error) {
        document.getElementById('logsSummary').innerHTML = '<div class="empty-message">加载失败</div>';
    }
}

async function loadPerformance() {
    try {
        const response = await fetch(`/api/executions/${currentExecutionId}/performance`);
        const metrics = await response.json();
        const container = document.getElementById('performanceMetrics');
        if (!metrics || metrics.error) { container.innerHTML = '<div class="empty-message">暂无性能指标</div>'; return; }
        const formatDuration = (ms) => { if (!ms) return '-'; if (ms < 1000) return ms + 'ms'; if (ms < 60000) return (ms).toFixed(1) + ' / 1000s'; return Math.floor(ms / 60000) + 'm ' + Math.round((ms % 60000) / 1000) + 's'; };
        container.innerHTML = `
            <div class="stat-row"><span class="stat-label">总耗时</span><span class="stat-value">${formatDuration(metrics.totalDuration)}</span></div>
            <div class="stat-row"><span class="stat-label">平均步骤耗时</span><span class="stat-value">${formatDuration(metrics.averageStepDuration)}</span></div>
            <div class="stat-row"><span class="stat-label">元素交互次数</span><span class="stat-value">${metrics.elementInteractions || 0}</span></div>
            ${metrics.slowestStep ? `<div class="stat-row"><span class="stat-label">最慢步骤</span><span class="stat-value" style="font-size: 14px;">步骤${metrics.slowestStep.order}: ${metrics.slowestStep.action}<br><small style="color: #f59e0b;">${formatDuration(metrics.slowestStep.duration)}</small></span></div>` : ''}
        `;
    } catch (error) {
        document.getElementById('performanceMetrics').innerHTML = '<div class="empty-message">加载失败</div>';
    }
}

async function loadEnvironment() {
    try {
        const response = await fetch(`/api/executions/${currentExecutionId}/environment`);
        const env = await response.json();
        const container = document.getElementById('environmentInfo');
        
        if (!env || env === null || env === '' || (typeof env === 'object' && Object.keys(env).length === 0) || env.error) { 
            container.innerHTML = '<div class="empty-message">暂无环境信息</div>'; 
            return; 
        }
        
        const browserInfo = env.browserVersion || '';
        const browserVersion = browserInfo.match(/(Chrome|Firefox|Safari|Edge)\/[\d.]+/)?.[0] || browserInfo || '-';
        
        container.innerHTML = `
            <div class="stat-row"><span class="stat-label">操作系统</span><span class="stat-value">${env.os} ${env.osVersion}</span></div>
            <div class="stat-row"><span class="stat-label">Node.js版本</span><span class="stat-value">${env.nodeVersion}</span></div>
            <div class="stat-row"><span class="stat-label">Playwright版本</span><span class="stat-value">${env.testPlatformVersion}</span></div>
            <div class="stat-row"><span class="stat-label">分辨率</span><span class="stat-value">${env.resolution}</span></div>
            <div class="stat-row"><span class="stat-label">浏览器</span><span class="stat-value">${browserVersion}</span></div>
        `;
    } catch (error) {
        document.getElementById('environmentInfo').innerHTML = '<div class="empty-message">暂无环境信息</div>';
    }
}

async function loadStructuredLogs(level = null) {
    try {
        let url = `/api/executions/${currentExecutionId}/structured-logs`;
        if (level) url += `?level=${level}`;
        const response = await fetch(url);
        currentLogs = await response.json();
        const container = document.getElementById('structuredLogs');
        if (!currentLogs || currentLogs.length === 0 || currentLogs.error) { container.innerHTML = '<div class="empty-message">暂无结构化日志</div>'; return; }
        const formatTime = (timestamp) => new Date(timestamp).toLocaleTimeString('zh-CN');
        
        container.innerHTML = currentLogs.map(log => {
            let fullMessage = log.message;
            const meta = log.metadata || {};
            
            if (meta.selector) {
                fullMessage += `: ${meta.selector}`;
                if (meta.value) {
                    fullMessage += `: ${meta.value}`;
                }
            }
            
            const isLong = fullMessage.length > 80;
            const messageClass = isLong ? 'log-message long' : 'log-message';
            
            return `
                <div class="log-entry log-${log.level}" data-level="${log.level}">
                    <span class="log-time">${formatTime(log.timestamp)}</span>
                    <span class="log-level-badge ${log.level}">${log.level}</span>
                    <span class="${messageClass}" title="${escapeHtml(fullMessage)}">${escapeHtml(fullMessage)}</span>
                    <div class="log-meta" style="margin-left: auto;">
                        ${log.stepOrder ? `<span class="log-meta-item">步骤 ${log.stepOrder}</span>` : ''}
                        ${meta.action ? `<span class="log-meta-item">${meta.action}</span>` : ''}
                        ${meta.duration ? `<span class="log-meta-item">${meta.duration}ms</span>` : ''}
                    </div>
                </div>
            `;
        }).join('');
    } catch (error) {
        document.getElementById('structuredLogs').innerHTML = '<div class="empty-message">加载失败</div>';
    }
}

function escapeHtml(text) { const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }

function filterLogs(level) {
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    event.target.classList.add('active');
    loadStructuredLogs(level === 'all' ? null : level);
}

async function loadRawJSON() {
    try {
        const response = await fetch(`/api/executions/${currentExecutionId}`);
        const data = await response.json();
        document.getElementById('rawJSONContent').textContent = JSON.stringify(data, null, 2);
    } catch (error) {
        document.getElementById('rawJSONContent').textContent = '加载失败';
    }
}

function toggleRawJSON() {
    const container = document.getElementById('rawJSON');
    const btn = document.getElementById('toggleRawBtn');
    container.style.display = container.style.display === 'none' ? 'block' : 'none';
    btn.textContent = container.style.display === 'none' ? '展开' : '收起';
}

function exportJSON() {
    if (!currentExecutionId) { alert('请先查询执行记录'); return; }
    window.open(`/api/executions/${currentExecutionId}/export-logs/json`, '_blank');
}

function exportCSV() {
    if (!currentExecutionId) { alert('请先查询执行记录'); return; }
    window.open(`/api/executions/${currentExecutionId}/export-logs/csv`, '_blank');
}

document.getElementById('executionId').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') queryExecution();
});
</script>
